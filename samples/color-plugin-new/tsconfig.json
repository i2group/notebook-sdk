{
  "compilerOptions": {
    "sourceMap": true,
    "module": "esnext",
    "target": "es2020",
    "lib": ["esnext"],
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "baseUrl": "./",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "downlevelIteration": true
  },
  "include": ["./src"]
}
